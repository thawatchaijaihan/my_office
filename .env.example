# LINE Messaging API (จาก LINE Developers Console)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Admin (ใช้ล็อก endpoint ฝั่งผู้ดูแล)
ADMIN_API_KEY=
# LINE userId ของแอดมิน (ใส่ได้หลายคน คั่นด้วย comma)
# ตัวอย่าง: Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
ADMIN_LINE_USER_IDS=

# Google Sheets API (Service Account)
# ใส่ "ไฟล์ key JSON" ของ service account แล้วแปลงเป็น base64 เก็บในตัวแปรนี้
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
# Spreadsheet ID (ค่าหลัง /d/ ใน URL)
GOOGLE_SHEETS_ID=

# Google Gemini API (จาก Google AI Studio)
GEMINI_API_KEY=

# (Optional) รูปแบบ model เช่น gemini-2.0-flash, gemini-1.5-flash
# GEMINI_MODEL=gemini-2.0-flash

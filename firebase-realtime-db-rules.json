{
  "rules": {
    ".read": false,
    ".write": false,
    "dashboardPreferences": {
      "$uid": {
        "review": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "cameras": {
      ".read": true,
      ".write": "auth != null"
    },
    "cctvReport": {
      ".read": true,
      ".write": true
    }
  }
}
